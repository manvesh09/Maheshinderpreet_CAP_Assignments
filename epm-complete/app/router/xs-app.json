{

  "welcomeFile": "index.html",

  "authenticationMethod": "none",

  "routes": [

    {

      "source": "^/catalog/(.*)$",

      "target": "/catalog/$1",

      "destination": "srv-api",

      "authenticationType": "xsuaa",

      "csrfProtection": true

    },

    {

      "source": "^/purchasing/(.*)$",

      "target": "/purchasing/$1",

      "destination": "srv-api",

      "authenticationType": "xsuaa",

      "csrfProtection": true

    },
    
     {
     "source": "^/(.*)$",
     "target": "$1",
     "localDir": "../project1/webapp",
     "authenticationType": "none"
   }
  ]

}
 